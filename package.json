{
  "name": "synclaro-ki-audit",
  "version": "1.0.0",
  "description": "Branchenoffener Synclaro AI-Readiness-Test mit adaptiven Fragen, festem Score und sicherer Lead-Strecke",
  "private": true,
  "scripts": {
    "test": "node --test tests/*.test.js",
    "test:netlify-manifest": "node scripts/assert-netlify-function-manifest.mjs",
    "test:migration": "./scripts/test-migration-local.sh",
    "check": "npm test && npm run test:migration && npm audit --audit-level=high"
  },
  "dependencies": {
    "@netlify/aws-lambda-compat": "1.0.2",
    "@supabase/supabase-js": "^2.110.7",
    "openai": "^4.85.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "resend": "^4.8.0"
  },
  "overrides": {
    "form-data": "4.0.6",
    "ws": "8.21.0"
  }
}
